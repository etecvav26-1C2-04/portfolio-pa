Exercício: Ler a base e altura de um triângulo. Calcular e exibir a área do triângulo
sabendo que área = base * altura / 2. 
*/

programa
{	
	funcao inicio() {
		
	inteiro base , altura, area

	escreva ("Qual a base do triângulo? ")
	leia (base) 

	escreva ("Qual a altura do triângulo? ")
	leia (altura)

   //calcular a área
	area = base * altura / 2

	escreva ("Área do triângulo: ", area)
	
	}
}
